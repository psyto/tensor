{
  "name": "@fabrknt/tensor-solana",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "crank": "tsx src/run-crank.ts",
    "vol-keeper": "tsx src/run-vol-keeper.ts",
    "liquidator": "tsx src/run-liquidator.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fabrknt/tensor-core": "workspace:*",
    "@solana/web3.js": "^1.95.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
